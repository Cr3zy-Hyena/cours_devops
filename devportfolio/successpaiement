{% extends 'base.html' %}
{% block title %}Paiement réussi{% endblock %}
{% block content %}

<div class="paiement-succes">
  <div class="paiement-icone">✅</div>
  <h1>Accès déverrouillé !</h1>
  <p>
    Votre accès au projet <strong>{{ projet.titre }}</strong> est maintenant actif.
  </p>
  {% if test_mode is defined and test_mode %}
  <p class="paiement-note">
    🧪 Simulation test — 0 € débité (mode <code>STRIPE_TEST_FREE=true</code>).
  </p>
  {% else %}
  <p class="paiement-note">
    (Simulation Stripe en mode test — aucun vrai débit effectué)
  </p>
  {% endif %}
  <a href="{{ url_for('main.detail_projet', id=projet.id) }}" class="btn-payer">
    Voir le projet déverrouillé →
  </a>
</div>

{% endblock %}