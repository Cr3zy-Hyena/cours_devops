          "instant": false,
          "legendFormat": "{{method}} {{status}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Requêtes HTTP par seconde",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "devportfolio-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
