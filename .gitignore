# Ignorer les caches et fichiers temporaires courants

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
pip-wheel-metadata/

# Virtual environment
env/
venv/
.venv/
ENV/

# Pytest cache
.pytest_cache/

# Mypy cache
.mypy_cache/

# Coverage reports
.coverage
.coverage.*
htmlcov/
coverage.xml

# tox
.tox/

# Editor directories and files
.idea/
.vscode/
*.swp
*~

# macOS
.DS_Store

# General cache dirs
.cache/
